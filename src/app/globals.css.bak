@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --background: #faf9f7;
  --foreground: #1a1a1a;
  --teal-primary: #0d9488;
  --teal-light: #14b8a6;
  --coral: #ef4444;
}

body {
  background-color: var(--background);
  color: var(--foreground);
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  -webkit-font-smoothing: antialiased;
}

.prose h1, .prose h2, .prose h3 {
  font-family: Georgia, Cambria, serif;
  font-weight: 700;
  color: #111827;
}

.prose h2 {
  font-size: 1.5rem;
  margin-top: 2rem;
  margin-bottom: 1rem;
}

.prose h3 {
  font-size: 1.25rem;
  margin-top: 1.5rem;
  margin-bottom: 0.75rem;
}

.prose p {
  margin-bottom: 1.25rem;
  line-height: 1.75;
  color: #374151;
}

.prose a {
  color: #0d9488;
  text-decoration: underline;
}

.prose a:hover {
  color: #0f766e;
}

.prose ul, .prose ol {
  padding-left: 1.5rem;
  margin-bottom: 1.25rem;
}

.prose li {
  margin-bottom: 0.5rem;
  color: #374151;
}

.prose strong {
  color: #111827;
  font-weight: 600;
}

.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
